{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "client/out",
        "lib": [
            "ES2020"
        ],
        "sourceMap": true,
        "rootDir": "client/src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "client/src/**/*"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
