{
    "name": "filament-mat-lsp",
    "displayName": "Filament Material LSP",
    "description": "Language Server Protocol support for Filament material files",
    "version": "0.0.1",
    "publisher": "your-publisher-name",
    "author": "Ruoxuan Fu",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/H5uan/filament-mat-lsp.git"
    },
    "bugs": {
        "url": "https://github.com/H5uan/filament-mat-lsp/issues"
    },
    "homepage": "https://github.com/H5uan/filament-mat-lsp#readme",
    "keywords": [
        "filament",
        "material",
        "lsp",
        "language-server",
        "vscode-extension",
        "graphics",
        "shader",
        "pbr"
    ],
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:filament-mat"
    ],
    "main": "./client/out/extension",
    "contributes": {
        "languages": [
            {
                "id": "filament-mat",
                "aliases": [
                    "Filament Material",
                    "filament-mat"
                ],
                "extensions": [
                    ".mat"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "filament-mat",
                "scopeName": "source.filament-mat",
                "path": "./syntaxes/filament-mat.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "filamentMat.compile",
                "title": "Compile Material",
                "category": "Filament Material"
            },
            {
                "command": "filamentMat.showDocumentation",
                "title": "Show Documentation",
                "category": "Filament Material"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "filamentMat.compile",
                    "when": "editorLangId == filament-mat",
                    "group": " Filament@1"
                }
            ]
        },
        "configuration": {
            "title": "Filament Material",
            "properties": {
                "filamentMat.matcPath": {
                    "type": "string",
                    "default": "matc",
                    "description": "Path to the Filament material compiler (matc)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile:rust && npm run compile:ts",
        "compile:rust": "cd native && cargo build --release",
        "compile:ts": "tsc -b",
        "watch": "tsc -b -w",
        "lint": "eslint ./client/src --ext .ts,.tsx",
        "postinstall": "cd client && npm install",
        "check": "npm run check:rust && npm run check:ts",
        "check:rust": "cd native && cargo fmt --all -- --check && cargo clippy -- -D warnings && cargo check --all && cargo test --all",
        "check:ts": "cd client && npx tsc --noEmit",
        "fix": "npm run fix:rust && npm run fix:ts",
        "fix:rust": "cd native && cargo fmt --all && cargo clippy --fix --allow-dirty -- -D warnings",
        "fix:ts": "cd client && npx tsc --noEmit",
        "test": "cd native && cargo test --all",
        "test:rust": "cd native && cargo test --all",
        "test:e2e": "tsc -b && node client/out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25",
        "@vscode/test-electron": "^2.5.2",
        "mocha": "^11.7.5",
        "typescript": "^6.0.3"
    }
}
