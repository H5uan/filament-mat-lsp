{
    "name": "filament-mat-lsp",
    "displayName": "Filament Material LSP",
    "description": "Language Server Protocol support for Filament material files",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:filament-mat"
    ],
    "main": "./client/out/extension",
    "contributes": {
        "languages": [
            {
                "id": "filament-mat",
                "aliases": [
                    "Filament Material",
                    "filament-mat"
                ],
                "extensions": [
                    ".mat"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "filament-mat",
                "scopeName": "source.filament-mat",
                "path": "./syntaxes/filament-mat.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile:rust && npm run compile:ts",
        "compile:rust": "cd native && cargo build --release",
        "compile:ts": "tsc -b",
        "watch": "tsc -b -w",
        "lint": "eslint ./client/src --ext .ts,.tsx",
        "postinstall": "cd client && npm install",

        "check": "npm run check:rust && npm run check:ts",
        "check:rust": "cd native && cargo fmt --all -- --check && cargo clippy -- -D warnings && cargo check --all && cargo test --all",
        "check:ts": "cd client && npx tsc --noEmit",

        "fix": "npm run fix:rust && npm run fix:ts",
        "fix:rust": "cd native && cargo fmt --all && cargo clippy --fix --allow-dirty -- -D warnings",
        "fix:ts": "cd client && npx tsc --noEmit",

        "test": "cd native && cargo test --all",
        "test:rust": "cd native && cargo test --all"
    },
    "devDependencies": {
        "@types/node": "^18",
        "typescript": "^5.0.0"
    }
}
